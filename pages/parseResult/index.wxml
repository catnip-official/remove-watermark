<view class="container">
  <view class="content">
    <!-- 视频信息卡片 -->
    <view class="video-card">
      <view class="video-cover">
        <video 
          wx:if="{{!videoData.isImage}}"
          class="video-player" 
          src="{{videoData.videoUrl}}" 
          poster="{{videoData.cover}}"
          object-fit="contain"
          referrer-policy="origin"
          custom-cache="{{false}}"
          controls
        ></video>
        <image
          wx:else
          class="video-player"
          src="{{videoData.videoUrl}}"
          mode="aspectFit"
          referrer-policy="origin"
        ></image>
      </view>
      <view class="video-info">
        <text class="video-title">{{videoData.title}}</text>
      </view>
    </view>

    <!-- 操作按钮卡片 -->
    <view class="actions-card">
      <!-- 核心操作：单独一行 -->
      <view class="btn btn-primary main-btn" bindtap="saveVideo">
        <text class="btn-text text-white">{{videoData.isImage ? '保存图片到相册' : '保存视频到相册'}}</text>
      </view>
      
      <!-- 次要操作：同一行 -->
      <view class="action-row sub-actions">
        <view class="btn btn-secondary sub-btn" bindtap="saveCover">
          <text class="btn-text sub-btn-text">保存封面</text>
        </view>
        <view class="btn btn-secondary sub-btn" bindtap="copyLink">
          <text class="btn-text sub-btn-text">复制链接</text>
        </view>
        <view class="btn btn-secondary sub-btn" bindtap="copyText">
          <text class="btn-text sub-btn-text">复制文案</text>
        </view>
      </view>
    </view>
  </view>
</view>