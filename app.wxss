page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  background-color: #F5F5F5;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

view, text, image, button, input, textarea {
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 16rpx;
  position: relative;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #87CEEB;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  background-color: #70b8d9;
  transform: scale(0.98);
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #FFFFFF;
  color: #87CEEB;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 2rpx solid #87CEEB;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background-color: #f0f9fc;
  transform: scale(0.98);
}

.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
}

.text-secondary {
  color: #999999;
  font-size: 24rpx;
}

.text-primary {
  color: #87CEEB;
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

.divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 24rpx 0;
}
